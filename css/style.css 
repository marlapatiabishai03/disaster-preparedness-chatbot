body {
    font-family: Arial;
    text-align: center;
    background: #eef2ff;
}

.chatbot {
    width: 320px;
    margin: 30px auto;
    padding: 15px;
    background: white;
    border: 1px solid #ccc;
}

.chatbot {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 320px;
    background: white;
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    overflow: hidden;
    z-index: 1000;
}

.chatbot.collapsed .chatbot-body,
.chatbot.collapsed .chatbot-input {
    display: none;
}

.chatbot-header {
    cursor: pointer;
}
/* Navbar Login Button */
.login-btn {
  margin-left: 20px;
  padding: 8px 16px;
  background-color: #ffffff;
  color: #1e3c72;
  border-radius: 5px;
  font-weight: bold;
  text-decoration: none;
  transition: 0.3s;
}

.login-btn:hover {
  background-color: #e6e6e6;
}
